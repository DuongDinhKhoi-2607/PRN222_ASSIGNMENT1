@model BussinessLayer.DTOs.LoginDto
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - RAG AI Assistant</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="/css/site.css" />
    <style>
        .auth-body {
            background: radial-gradient(circle at top right, #1a153b, #0d0f14 60%);
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
            overflow: hidden;
            margin: 0;
            padding: 1.5rem;
        }
        .auth-container {
            width: 100%;
            max-width: 440px;
            perspective: 1000px;
        }
        .auth-card {
            background: rgba(19, 22, 30, 0.7);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: var(--radius-xl);
            padding: 2.5rem;
            box-shadow: var(--shadow-lg), 0 0 40px rgba(108, 99, 255, 0.15);
            animation: card-appear 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        }
        @@keyframes card-appear {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .auth-logo {
            width: 54px;
            height: 54px;
            background: linear-gradient(135deg, var(--accent), #a78bfa);
            border-radius: var(--radius-md);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 1.5rem;
            margin: 0 auto 1.25rem;
            box-shadow: 0 0 20px var(--accent-glow);
        }
        .auth-header {
            text-align: center;
            margin-bottom: 2rem;
        }
        .auth-title {
            font-size: 1.35rem;
            font-weight: 700;
            background: linear-gradient(135deg, #fff, #a78bfa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 0.5rem;
        }
        .auth-subtitle {
            font-size: 0.8rem;
            color: var(--text-secondary);
        }
        .auth-btn {
            margin-top: 1.5rem;
            height: 44px;
            background: linear-gradient(135deg, var(--accent), #a78bfa);
            box-shadow: 0 4px 16px var(--accent-glow);
        }
        .auth-btn:hover {
            box-shadow: 0 6px 24px var(--accent-glow);
        }
        .auth-link {
            text-align: center;
            margin-top: 1.5rem;
            font-size: 0.8rem;
            color: var(--text-secondary);
        }
        .auth-link a {
            color: var(--accent-2);
            text-decoration: none;
            font-weight: 600;
            transition: color var(--transition);
        }
        .auth-link a:hover {
            color: #fff;
            text-shadow: 0 0 8px var(--accent-2-glow);
        }
        .input-group-custom {
            position: relative;
            margin-bottom: 1.25rem;
        }
        .input-icon-custom {
            position: absolute;
            left: 0.95rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            font-size: 0.95rem;
            pointer-events: none;
            transition: color var(--transition);
        }
        .form-input-custom {
            padding-left: 2.6rem !important;
        }
        .form-input-custom:focus + .input-icon-custom {
            color: var(--accent-2);
        }
        .error-alert {
            background: rgba(255, 77, 109, 0.1);
            border: 1px solid rgba(255, 77, 109, 0.25);
            color: #ff6b84;
            padding: 0.75rem 1rem;
            border-radius: var(--radius-sm);
            font-size: 0.8rem;
            margin-bottom: 1.25rem;
            display: flex;
            align-items: center;
            gap: 0.6rem;
        }
    </style>
</head>
<body class="auth-body">

    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-logo">
                <i class="fa-solid fa-brain"></i>
            </div>
            
            <div class="auth-header">
                <h1 class="auth-title">RAG AI Assistant</h1>
                <p class="auth-subtitle">Đăng nhập để đặt câu hỏi hoặc tải lên tài liệu học tập</p>
            </div>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert-box show success" style="margin-bottom: 1.25rem; background: rgba(0, 212, 170, 0.1); border: 1px solid rgba(0, 212, 170, 0.25); color: #00d4aa; padding: 0.75rem 1rem; border-radius: var(--radius-sm); font-size: 0.8rem; display: flex; align-items: center; gap: 0.6rem;">
                    <i class="fa-solid fa-circle-check"></i>
                    <span>@TempData["SuccessMessage"]</span>
                </div>
            }

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="error-alert">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <span>@string.Join(" ", ViewData.ModelState.Values.SelectMany(v => v.Errors).Select(e => e.ErrorMessage))</span>
                </div>
            }

            <form method="post" asp-action="Login" asp-controller="Auth">
                <input type="hidden" asp-for="ReturnUrl" />

                <div class="input-group-custom">
                    <label class="form-label" for="email">Địa chỉ Email</label>
                    <input id="email" type="email" asp-for="Email" class="form-input form-input-custom" placeholder="name@domain.com" required autocomplete="email" />
                    <i class="fa-solid fa-envelope input-icon-custom"></i>
                </div>

                <div class="input-group-custom" style="margin-bottom: 1.5rem;">
                    <label class="form-label" for="password">Mật khẩu</label>
                    <input id="password" type="password" asp-for="Password" class="form-input form-input-custom" placeholder="••••••••" required />
                    <i class="fa-solid fa-lock input-icon-custom"></i>
                </div>

                <button type="submit" class="btn-primary auth-btn">
                    <i class="fa-solid fa-right-to-bracket"></i> Đăng nhập
                </button>
            </form>

            <div class="auth-link">
                Chưa có tài khoản? <a href="/Auth/Register?returnUrl=@Model.ReturnUrl">Đăng ký ngay</a>
            </div>
        </div>
    </div>

</body>
</html>
