@model BussinessLayer.DTOs.RegisterDto
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng ký tài khoản - RAG AI Assistant</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="/css/site.css" />
    <style>
        .auth-body {
            background: radial-gradient(circle at top right, #15253b, #0d0f14 60%);
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
            overflow: hidden;
            margin: 0;
            padding: 1.5rem;
        }
        .auth-container {
            width: 100%;
            max-width: 460px;
            perspective: 1000px;
        }
        .auth-card {
            background: rgba(19, 22, 30, 0.7);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: var(--radius-xl);
            padding: 2.5rem;
            box-shadow: var(--shadow-lg), 0 0 40px rgba(0, 212, 170, 0.1);
            animation: card-appear 0.5s cubic-bezier(0.16, 1, 0.3, 1);
            max-height: 90vh;
            overflow-y: auto;
        }
        .auth-card::-webkit-scrollbar {
            width: 4px;
        }
        .auth-card::-webkit-scrollbar-track {
            background: transparent;
        }
        .auth-card::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 4px;
        }
        @@keyframes card-appear {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .auth-logo {
            width: 54px;
            height: 54px;
            background: linear-gradient(135deg, var(--accent-2), #00b090);
            border-radius: var(--radius-md);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 1.5rem;
            margin: 0 auto 1.25rem;
            box-shadow: 0 0 20px var(--accent-2-glow);
        }
        .auth-header {
            text-align: center;
            margin-bottom: 1.5rem;
        }
        .auth-title {
            font-size: 1.35rem;
            font-weight: 700;
            background: linear-gradient(135deg, #fff, var(--accent-2));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 0.5rem;
        }
        .auth-subtitle {
            font-size: 0.8rem;
            color: var(--text-secondary);
        }
        .auth-btn {
            margin-top: 1.5rem;
            height: 44px;
            background: linear-gradient(135deg, var(--accent-2), #00b090);
            box-shadow: 0 4px 16px var(--accent-2-glow);
        }
        .auth-btn:hover {
            box-shadow: 0 6px 24px var(--accent-2-glow);
        }
        .auth-link {
            text-align: center;
            margin-top: 1.5rem;
            font-size: 0.8rem;
            color: var(--text-secondary);
        }
        .auth-link a {
            color: var(--accent);
            text-decoration: none;
            font-weight: 600;
            transition: color var(--transition);
        }
        .auth-link a:hover {
            color: #fff;
            text-shadow: 0 0 8px var(--accent-glow);
        }
        .input-group-custom {
            position: relative;
            margin-bottom: 1rem;
        }
        .input-icon-custom {
            position: absolute;
            left: 0.95rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            font-size: 0.95rem;
            pointer-events: none;
            transition: color var(--transition);
        }
        .form-input-custom {
            padding-left: 2.6rem !important;
        }
        .form-input-custom:focus + .input-icon-custom {
            color: var(--accent-2);
        }
        .error-alert {
            background: rgba(255, 77, 109, 0.1);
            border: 1px solid rgba(255, 77, 109, 0.25);
            color: #ff6b84;
            padding: 0.75rem 1rem;
            border-radius: var(--radius-sm);
            font-size: 0.8rem;
            margin-bottom: 1.25rem;
            display: flex;
            align-items: center;
            gap: 0.6rem;
        }
        .role-selector {
            display: flex;
            gap: 1rem;
            margin-top: 0.25rem;
        }
        .role-option {
            flex: 1;
            position: relative;
        }
        .role-option input {
            position: absolute;
            opacity: 0;
            width: 0;
            height: 0;
        }
        .role-card {
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: 0.75rem;
            text-align: center;
            cursor: pointer;
            transition: all var(--transition);
            background: var(--bg-elevated);
        }
        .role-card i {
            font-size: 1.25rem;
            margin-bottom: 0.35rem;
            display: block;
            color: var(--text-muted);
            transition: color var(--transition);
        }
        .role-card span {
            font-size: 0.8rem;
            font-weight: 500;
            color: var(--text-secondary);
            transition: color var(--transition);
        }
        .role-option input:checked + .role-card {
            border-color: var(--accent-2);
            background: rgba(0, 212, 170, 0.08);
            box-shadow: 0 0 12px var(--accent-2-glow);
        }
        .role-option input:checked + .role-card i {
            color: var(--accent-2);
        }
        .role-option input:checked + .role-card span {
            color: #fff;
        }
    </style>
</head>
<body class="auth-body">

    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-logo">
                <i class="fa-solid fa-user-plus"></i>
            </div>
            
            <div class="auth-header">
                <h1 class="auth-title">Đăng Ký Tài Khoản</h1>
                <p class="auth-subtitle">Trải nghiệm hệ thống trợ lý học tập RAG AI thông minh</p>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="error-alert">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <span>@string.Join(" ", ViewData.ModelState.Values.SelectMany(v => v.Errors).Select(e => e.ErrorMessage))</span>
                </div>
            }

            <form method="post" asp-action="Register" asp-controller="Auth">
                <input type="hidden" asp-for="ReturnUrl" />

                <div class="input-group-custom">
                    <label class="form-label" for="fullName">Họ và Tên</label>
                    <input id="fullName" type="text" asp-for="FullName" class="form-input form-input-custom" placeholder="Nguyễn Văn A" required />
                    <i class="fa-solid fa-user input-icon-custom"></i>
                </div>

                <div class="input-group-custom">
                    <label class="form-label" for="email">Địa chỉ Email</label>
                    <input id="email" type="email" asp-for="Email" class="form-input form-input-custom" placeholder="name@domain.com" required autocomplete="email" />
                    <i class="fa-solid fa-envelope input-icon-custom"></i>
                </div>

                <div class="form-group">
                    <label class="form-label">Bạn là?</label>
                    <div class="role-selector">
                        <label class="role-option">
                            <input type="radio" asp-for="Role" value="student" checked />
                            <div class="role-card">
                                <i class="fa-solid fa-graduation-cap"></i>
                                <span>Sinh viên</span>
                            </div>
                        </label>
                        <label class="role-option">
                            <input type="radio" asp-for="Role" value="lecturer" />
                            <div class="role-card">
                                <i class="fa-solid fa-chalkboard-user"></i>
                                <span>Giảng viên</span>
                            </div>
                        </label>
                    </div>
                </div>

                <div class="input-group-custom">
                    <label class="form-label" for="password">Mật khẩu</label>
                    <input id="password" type="password" asp-for="Password" class="form-input form-input-custom" placeholder="Tối thiểu 6 ký tự" required />
                    <i class="fa-solid fa-lock input-icon-custom"></i>
                </div>

                <div class="input-group-custom">
                    <label class="form-label" for="confirmPassword">Xác nhận mật khẩu</label>
                    <input id="confirmPassword" type="password" asp-for="ConfirmPassword" class="form-input form-input-custom" placeholder="Nhập lại mật khẩu" required />
                    <i class="fa-solid fa-shield-halved input-icon-custom"></i>
                </div>

                <button type="submit" class="btn-primary auth-btn">
                    <i class="fa-solid fa-user-plus"></i> Đăng ký tài khoản
                </button>
            </form>

            <div class="auth-link">
                Đã có tài khoản? <a href="/Auth/Login?returnUrl=@Model.ReturnUrl">Đăng nhập</a>
            </div>
        </div>
    </div>

</body>
</html>
