@model SubjectDto
@{
    ViewData["Title"] = "Tạo Môn học";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
.crud-page { height: 100%; overflow-y: auto; padding: 2rem; }
.crud-page::-webkit-scrollbar { width: 4px; }
.crud-page::-webkit-scrollbar-thumb { background: var(--border-strong); border-radius: 4px; }
.form-card {
    max-width: 560px;
    margin: 0 auto;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
}
.form-card-header {
    padding: 1.5rem 2rem;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: .85rem;
    background: var(--bg-elevated);
}
.form-card-icon {
    width: 42px; height: 42px;
    background: linear-gradient(135deg, var(--accent), #a78bfa);
    border-radius: var(--radius-sm);
    display: flex; align-items: center; justify-content: center;
    color: #fff;
    font-size: 1.1rem;
    box-shadow: 0 0 16px var(--accent-glow);
    flex-shrink: 0;
}
.form-card-title { font-size: 1.05rem; font-weight: 700; color: var(--text-primary); }
.form-card-subtitle { font-size: .75rem; color: var(--text-muted); margin-top: .1rem; }
.form-card-body { padding: 2rem; }

.field-group { margin-bottom: 1.5rem; }
.field-label {
    display: block;
    font-size: .78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: var(--text-muted);
    margin-bottom: .55rem;
}
.field-label .required { color: var(--accent-danger); margin-left: .2rem; }
.field-input {
    width: 100%;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text-primary);
    padding: .75rem 1rem;
    font-size: .9rem;
    font-family: 'Inter', sans-serif;
    transition: all var(--transition);
}
.field-input:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-glow); }
.field-input::placeholder { color: var(--text-muted); }
.field-error { font-size: .75rem; color: var(--accent-danger); margin-top: .4rem; display: flex; align-items: center; gap: .3rem; }
.field-validation-valid { display: none !important; }

.form-actions {
    display: flex;
    gap: .75rem;
    padding: 1.25rem 2rem;
    border-top: 1px solid var(--border);
    background: var(--bg-elevated);
}
.btn-submit {
    display: inline-flex; align-items: center; gap: .5rem;
    padding: .7rem 1.5rem;
    background: linear-gradient(135deg, var(--accent), #a78bfa);
    border: none; border-radius: var(--radius-sm);
    color: #fff; font-size: .875rem; font-weight: 600;
    font-family: 'Inter', sans-serif; cursor: pointer;
    transition: all var(--transition);
    box-shadow: 0 4px 16px var(--accent-glow);
    text-decoration: none;
}
.btn-submit:hover { transform: translateY(-1px); box-shadow: 0 8px 24px var(--accent-glow); color: #fff; }
.btn-cancel {
    display: inline-flex; align-items: center; gap: .5rem;
    padding: .7rem 1.25rem;
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: var(--radius-sm); color: var(--text-secondary);
    font-size: .875rem; font-weight: 500; font-family: 'Inter', sans-serif;
    cursor: pointer; transition: all var(--transition); text-decoration: none;
}
.btn-cancel:hover { background: var(--bg-hover); color: var(--text-primary); border-color: var(--border-strong); }
</style>

<div class="crud-page">
    <div class="form-card">
        <div class="form-card-header">
            <div class="form-card-icon"><i class="fa-solid fa-plus"></i></div>
            <div>
                <div class="form-card-title">Tạo Môn học mới</div>
                <div class="form-card-subtitle">Thêm môn học vào hệ thống RAG</div>
            </div>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div style="margin: 1.5rem 2rem 0; padding: .9rem 1.25rem; background: rgba(0,212,170,.08); border: 1px solid rgba(0,212,170,.2); border-radius: var(--radius-md); color: var(--accent-2); font-size: .85rem; display: flex; align-items: flex-start; gap: .75rem;">
                <i class="fa-solid fa-circle-check" style="flex-shrink:0;margin-top:.1rem"></i>
                <div>@TempData["SuccessMessage"]</div>
            </div>
        }

        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="form-card-body">
                <div class="field-group">
                    <label class="field-label">Mã môn học <span class="required">*</span></label>
                    <input asp-for="Code" class="field-input" placeholder="VD: PRN222, INT301" maxlength="50" />
                    <span asp-validation-for="Code" class="field-error"></span>
                </div>

                <div class="field-group">
                    <label class="field-label">Tên môn học <span class="required">*</span></label>
                    <input asp-for="Name" class="field-input" placeholder="VD: Lập trình Web với ASP.NET Core" />
                    <span asp-validation-for="Name" class="field-error"></span>
                </div>

                <div class="field-group" style="margin-bottom:0">
                    <label class="field-label">Mô tả <span style="color:var(--text-muted);font-weight:400;text-transform:none;letter-spacing:0">(không bắt buộc)</span></label>
                    <textarea asp-for="Description" class="field-input" rows="3" placeholder="Mô tả ngắn về môn học…" style="resize:vertical"></textarea>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-submit">
                    <i class="fa-solid fa-check"></i> Tạo môn học
                </button>
                <a asp-action="Index" class="btn-cancel">
                    <i class="fa-solid fa-arrow-left"></i> Hủy
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
