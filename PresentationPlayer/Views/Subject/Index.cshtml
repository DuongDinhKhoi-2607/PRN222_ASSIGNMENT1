@model IEnumerable<SubjectDto>
@{
    ViewData["Title"] = "Môn học";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
.crud-page { height: 100%; overflow-y: auto; padding: 2rem; }
.crud-page::-webkit-scrollbar { width: 4px; }
.crud-page::-webkit-scrollbar-thumb { background: var(--border-strong); border-radius: 4px; }

.page-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
}
.page-heading {
    font-size: 1.4rem;
    font-weight: 700;
    background: linear-gradient(135deg, #fff, #a78bfa);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    display: flex;
    align-items: center;
    gap: .65rem;
}
.page-heading i { -webkit-text-fill-color: var(--accent); }

.btn-add {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    padding: .6rem 1.25rem;
    background: linear-gradient(135deg, var(--accent), #a78bfa);
    border: none;
    border-radius: var(--radius-sm);
    color: #fff;
    font-size: .85rem;
    font-weight: 600;
    font-family: 'Inter', sans-serif;
    cursor: pointer;
    text-decoration: none;
    transition: all var(--transition);
    box-shadow: 0 4px 16px var(--accent-glow);
}
.btn-add:hover { transform: translateY(-1px); box-shadow: 0 8px 24px var(--accent-glow); color: #fff; }

.alert-success-bar {
    display: flex;
    align-items: center;
    gap: .75rem;
    padding: .85rem 1.25rem;
    background: rgba(0,212,170,.1);
    border: 1px solid rgba(0,212,170,.25);
    border-radius: var(--radius-md);
    color: var(--accent-2);
    font-size: .85rem;
    margin-bottom: 1.5rem;
    animation: msg-in .25s ease;
}

.alert-error-bar {
    display: flex;
    align-items: center;
    gap: .75rem;
    padding: .85rem 1.25rem;
    background: rgba(255,77,109,.1);
    border: 1px solid rgba(255,77,109,.25);
    border-radius: var(--radius-md);
    color: var(--accent-danger);
    font-size: .85rem;
    margin-bottom: 1.5rem;
    animation: msg-in .25s ease;
}

.empty-state {
    text-align: center;
    padding: 4rem 2rem;
    color: var(--text-muted);
}
.empty-state i { font-size: 3rem; margin-bottom: 1rem; display: block; opacity: .3; }
.empty-state p { font-size: .9rem; }

/* Data table */
.data-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
}
.data-table thead tr {
    background: var(--bg-elevated);
}
.data-table th {
    padding: .9rem 1.25rem;
    font-size: .72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .07em;
    color: var(--text-muted);
    text-align: left;
    border-bottom: 1px solid var(--border);
}
.data-table td {
    padding: .9rem 1.25rem;
    font-size: .875rem;
    color: var(--text-primary);
    border-bottom: 1px solid var(--border);
    vertical-align: middle;
}
.data-table tbody tr:last-child td { border-bottom: none; }
.data-table tbody tr { transition: background var(--transition); }
.data-table tbody tr:hover { background: var(--bg-hover); }

.badge-code {
    display: inline-flex;
    align-items: center;
    padding: .25rem .7rem;
    background: rgba(108,99,255,.15);
    border: 1px solid rgba(108,99,255,.3);
    border-radius: 999px;
    font-size: .75rem;
    font-weight: 600;
    color: #a78bfa;
    letter-spacing: .03em;
}

.action-group { display: flex; gap: .4rem; align-items: center; }

.btn-action {
    width: 30px; height: 30px;
    display: inline-flex; align-items: center; justify-content: center;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: var(--bg-elevated);
    color: var(--text-secondary);
    font-size: .8rem;
    text-decoration: none;
    transition: all var(--transition);
    cursor: pointer;
}
.btn-action:hover { transform: translateY(-1px); }
.btn-action.view:hover  { background: rgba(0,212,170,.15); border-color: rgba(0,212,170,.4); color: var(--accent-2); }
.btn-action.edit:hover  { background: rgba(255,183,3,.15); border-color: rgba(255,183,3,.4); color: var(--accent-warn); }
.btn-action.delete:hover { background: rgba(255,77,109,.15); border-color: rgba(255,77,109,.4); color: var(--accent-danger); }
</style>

<div class="crud-page">
    <div class="page-header">
        <h1 class="page-heading">
            <i class="fa-solid fa-book"></i>
            Danh sách Môn học
        </h1>
        @if (User.IsInRole("admin"))
        {
            <a asp-action="Create" class="btn-add">
                <i class="fa-solid fa-plus"></i> Tạo môn học mới
            </a>
        }
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert-success-bar">
            <i class="fa-solid fa-circle-check"></i>
            <span>@TempData["SuccessMessage"]</span>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert-error-bar">
            <i class="fa-solid fa-circle-exclamation"></i>
            <span>@TempData["ErrorMessage"]</span>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="card">
            <div class="empty-state">
                <i class="fa-solid fa-book-open"></i>
                <p>Chưa có môn học nào. Hãy tạo môn học đầu tiên!</p>
            </div>
        </div>
    }
    else
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Mã môn học</th>
                    <th>Tên môn học</th>
                    <th>Mô tả</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model)
                {
                    <tr>
                        <td style="color:var(--text-muted);width:60px">@s.Id</td>
                        <td><span class="badge-code">@s.Code</span></td>
                        <td style="font-weight:500">@s.Name</td>
                        <td style="color:var(--text-secondary)">@(s.Description ?? "—")</td>
                        <td>
                            <div class="action-group">
                                <a asp-action="Details" asp-route-id="@s.Id" class="btn-action view" title="Chi tiết">
                                    <i class="fa-solid fa-eye"></i>
                                </a>
                                @if (User.IsInRole("admin"))
                                {
                                    <a asp-action="Edit" asp-route-id="@s.Id" class="btn-action edit" title="Sửa">
                                        <i class="fa-solid fa-pen"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@s.Id" class="btn-action delete" title="Xóa">
                                        <i class="fa-solid fa-trash"></i>
                                    </a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
