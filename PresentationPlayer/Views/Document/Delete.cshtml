@model DocumentDto
@{
    ViewData["Title"] = "Xóa Tài liệu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
.crud-page { height: 100%; overflow-y: auto; padding: 2rem; }
.form-card { max-width: 520px; margin: 0 auto; background: var(--bg-card); border: 1px solid rgba(255,77,109,.2); border-radius: var(--radius-lg); overflow: hidden; box-shadow: 0 0 40px rgba(255,77,109,.07); }
.form-card-header { padding: 1.5rem 2rem; border-bottom: 1px solid rgba(255,77,109,.15); display: flex; align-items: center; gap: .85rem; background: rgba(255,77,109,.06); }
.form-card-icon { width: 42px; height: 42px; background: linear-gradient(135deg, var(--accent-danger), #c0392b); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 1.1rem; box-shadow: 0 0 16px rgba(255,77,109,.4); flex-shrink: 0; }
.form-card-title { font-size: 1.05rem; font-weight: 700; color: var(--text-primary); }
.form-card-subtitle { font-size: .75rem; color: rgba(255,107,132,.7); margin-top: .1rem; }
.warn-box { margin: 1.5rem 2rem; padding: .9rem 1.25rem; background: rgba(255,77,109,.08); border: 1px solid rgba(255,77,109,.2); border-radius: var(--radius-md); color: #ff6b84; font-size: .85rem; display: flex; align-items: flex-start; gap: .75rem; line-height: 1.5; }
.detail-list { padding: 0 2rem 1.5rem; display: flex; flex-direction: column; gap: 1rem; }
.detail-row { display: grid; grid-template-columns: 110px 1fr; gap: 1rem; align-items: start; padding-bottom: 1rem; border-bottom: 1px solid var(--border); }
.detail-row:last-child { border-bottom: none; padding-bottom: 0; }
.detail-key { font-size: .72rem; font-weight: 600; text-transform: uppercase; letter-spacing: .06em; color: var(--text-muted); }
.badge-file { background: rgba(255,77,109,.12); border: 1px solid rgba(255,77,109,.25); border-radius: 4px; padding: .1rem .45rem; font-size: .72rem; color: #ff6b84; }
.form-actions { display: flex; gap: .75rem; padding: 1.25rem 2rem; border-top: 1px solid rgba(255,77,109,.15); background: rgba(255,77,109,.04); }
.btn-delete { display: inline-flex; align-items: center; gap: .5rem; padding: .7rem 1.5rem; background: linear-gradient(135deg, var(--accent-danger), #c0392b); border: none; border-radius: var(--radius-sm); color: #fff; font-size: .875rem; font-weight: 600; font-family: 'Inter', sans-serif; cursor: pointer; transition: all var(--transition); box-shadow: 0 4px 16px rgba(255,77,109,.35); }
.btn-delete:hover { transform: translateY(-1px); box-shadow: 0 8px 24px rgba(255,77,109,.5); }
.btn-cancel { display: inline-flex; align-items: center; gap: .5rem; padding: .7rem 1.25rem; background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-sm); color: var(--text-secondary); font-size: .875rem; font-weight: 500; font-family: 'Inter', sans-serif; cursor: pointer; transition: all var(--transition); text-decoration: none; }
.btn-cancel:hover { background: var(--bg-hover); color: var(--text-primary); }
</style>

<div class="crud-page">
    <div class="form-card">
        <div class="form-card-header">
            <div class="form-card-icon"><i class="fa-solid fa-trash"></i></div>
            <div>
                <div class="form-card-title">Xác nhận Xóa Tài liệu</div>
                <div class="form-card-subtitle">Thao tác này sẽ xóa vector và dữ liệu RAG</div>
            </div>
        </div>

        <div class="warn-box">
            <i class="fa-solid fa-triangle-exclamation" style="flex-shrink:0;margin-top:.1rem"></i>
            <span>Hành động này sẽ <strong>xóa vĩnh viễn</strong> toàn bộ nội dung vector và lịch sử RAG liên quan đến tài liệu này và <strong>không thể hoàn tác</strong>.</span>
        </div>

        <div class="detail-list">
            <div class="detail-row">
                <span class="detail-key">Tiêu đề</span>
                <span style="font-size:.875rem;font-weight:600;color:var(--text-primary)">@Model.Title</span>
            </div>
            <div class="detail-row">
                <span class="detail-key">File</span>
                <span style="font-size:.875rem;color:var(--text-secondary)">
                    @Model.FileName
                    <span class="badge-file">@Model.FileType</span>
                </span>
            </div>
            <div class="detail-row">
                <span class="detail-key">Môn học</span>
                <span style="font-size:.875rem;color:var(--text-secondary)">[@Model.SubjectCode] @Model.SubjectName</span>
            </div>
            <div class="detail-row">
                <span class="detail-key">Trạng thái</span>
                <span style="font-size:.8rem;color:var(--text-muted)">@Model.Status</span>
            </div>
        </div>

        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
            <div class="form-actions">
                <button type="submit" class="btn-delete">
                    <i class="fa-solid fa-trash"></i> Xác nhận xóa
                </button>
                <a href="@(string.IsNullOrEmpty(ViewBag.ReturnUrl as string) ? "/Document/Index" : ViewBag.ReturnUrl)" class="btn-cancel">
                    <i class="fa-solid fa-arrow-left"></i> Hủy
                </a>
            </div>
        </form>
    </div>
</div>
